# === 4 обязательных параметра ===

# Твой Telegram ID (узнать: отправь /start боту @userinfobot)
TELEGRAM_ADMIN_ID=123456789

# Токен бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Anthropic setup-token от подписки Claude Pro/Max
# Получить: запусти "claude setup-token" в терминале на любом устройстве с Claude CLI
ANTHROPIC_SETUP_TOKEN=sk-ant-oat01-xxx

# API ключ OpenRouter — fallback если Anthropic недоступен (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxx
